# Auto detect text files and perform LF normalization
* text=auto

# TypeScript/JavaScript - always use LF
*.ts text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# JSON/YAML - always use LF
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Markdown - always use LF
*.md text eol=lf

# Config files - always use LF
*.config text eol=lf
.editorconfig text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf
.prettierrc text eol=lf
.eslintrc text eol=lf
tsconfig.json text eol=lf

# Shell scripts - always use LF
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
